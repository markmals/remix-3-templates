{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "jsxImportSource": "remix/component",
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "types": [
            "@types/node",
            "@types/bun",
            "vite/client",
            "@hiogawa/vite-plugin-fullstack/types"
        ]
    },
    "include": ["app"]
}
