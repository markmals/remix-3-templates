{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "jsxImportSource": "remix/component",
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "lib": ["DOM", "DOM.Iterable", "ESNext", "WebWorker"],
        "types": ["vite/client", "@hiogawa/vite-plugin-fullstack/types"]
    },
    "include": ["app"]
}
