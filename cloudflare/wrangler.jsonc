{
  "name": "remix-3-cloudflare",
  "main": "app/entry.server.tsx",
  "assets": {
    "directory": "dist/client",
  },
  "compatibility_date": "2026-04-02",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "remix-3-cloudflare-db",
      "database_id": "local",
    },
  ],
}
